{
  "_meta": {
    "version": "1.2.0",
    "strategy": "gale_core_gamma_premium",
    "profile": "core",
    "last_updated": "2026-05-27",
    "notes": "v1.2.0: agrega definiciones leg_mid_price, max_profit, max_loss, buying_power_requirement. Amplía pop_proxy. Agrega display_config.portfolio_manager_table. Premiums y net_credit son realtime=true: vienen del socket (ReceiveQuote por OCC symbol), no del REST. Backend expone strikeEngine.legSymbols para que el frontend sepa qué suscribir."
  },
  "principles": {
    "cash_is_a_position": true,
    "execution_quality_over_frequency": true,
    "survival_over_trade_count": true,
    "defined_risk_only": true,
    "no_binary_macro_risk": true
  },
  "strategy_scope": {
    "allowed_strategies": ["iron_condor", "put_credit_spread", "call_credit_spread"],
    "forbidden_strategies": ["naked_short_put", "naked_short_call", "ratio_spread", "long_directional"],
    "default_structure": "iron_condor",
    "structure_selection_method": "multi_factor"
  },
  "universe": {
    "mode": "whitelist",
    "tickers": [ "SPY", "QQQ" ],
    "min_avg_daily_volume_underlying": 5000000
  },
  "data_availability": {
    "available_today": [
      "iv_rank", "iv_percentile", "iv9d", "iv30", "iv3m",
      "iv_zscore_from_252d_history",
      "gex_net_billions", "gex_skew_call_put_ratio", "gamma_zero_level", "call_wall", "put_wall",
      "gex_by_strike", "delta_by_strike", "oi_by_strike",
      "spot_price", "vix_absolute_via_ticker",
      "bid_ask_quote", "account_net_liq", "account_positions",
      "daily_candles_ohlcv", "ema_20_50_from_candles",
      "realized_vol_short_long_from_candles",
      "realtime_trade_quote_greeks_bundled",
      "aggressive_flow_ask_side_from_stream"
    ],
    "manual_check_required": [
      "fomc_cpi_calendar",
      "spy_ex_dividend_date"
    ],
    "partial_availability_note": {
      "oi_intraday_opening_detection": "Solo OI diario disponible vía candles. Proxy: day_volume / oi_prev_day >= 0.5 para inferir apertura neta."
    }
  },
  "data_quality": {
    "max_quote_age_seconds": 15,
    "max_structural_levels_age_minutes": 15,
    "block_on_crossed_market": true,
    "block_on_missing_critical_data": true
  },
  "operators": {
    "_description": "Enum cerrado de operadores soportados por el motor de checks.",
    "values": ["gte", "lte", "gt", "lt", "eq", "between", "custom"]
  },
  "on_fail_actions": {
    "_description": "Enum cerrado de acciones cuando un check falla.",
    "values": [
      "no_trade",
      "discard_side",
      "discard_put_side",
      "discard_call_side",
      "wait_for_stabilization",
      "block_until_fresh",
      "block_new_entries",
      "block_new_call_entries",
      "warn",
      "degrade_structure",
      "try_wider_spread_then_discard",
      "reduce_contracts_to_fit_or_discard"
    ]
  },
  "definitions": {
    "_note": "Fuente única de verdad para fórmulas y lookups. Los checks referencian aquí vía { ref: 'definitions.X' }.",
    "iv_rank": {
      "type": "formula",
      "formula": "((iv_current - iv_min_252) / (iv_max_252 - iv_min_252)) * 100",
      "source": "30d_continuous_atm_iv",
      "lookback_trading_sessions": 252,
      "endpoint": "/App.Analytics/IVRank"
    },
    "iv30_atm_roc_pct": {
      "type": "formula",
      "formula": "((iv30_today - iv30_5d_ago) / iv30_5d_ago) * 100",
      "window_days": 5,
      "iv30_today": {
        "source": "/Data/Tastytrade/Market-metrics/VolatilityData → impliedVolatilityIndex (×100)",
        "field": "IV30_0d"
      },
      "iv30_5d_ago": {
        "source": "/Data/Tastytrade/Market-metrics/VolatilityData → impliedVolatilityIndex - impliedVolatilityIndex5DayChange (×100)",
        "field": "IV30_5d"
      },
      "endpoint": "/App.Analytics/ImpliedVolatility → IV30RocPct"
    },
    "expected_move": {
      "type": "formula",
      "formula": "spot * iv_atm * sqrt(dte / 365)",
      "iv_source": "atm_iv_of_target_expiration_cycle",
      "rounding_rule": "calculate_exact_then_round_to_nearest_tradeable_strike",
      "endpoint": "derived from /App.Analytics/ImpliedVolatility + /Data/Tastytrade/MarketData/ByType"
    },
    "directional_zscore": {
      "type": "formula",
      "formula": "ret_5d / (iv_atm / sqrt(252))",
      "ret_5d": "cumulative_log_return_last_5_trading_sessions",
      "iv_atm": "atm_iv_30d_annualised",
      "endpoint": "derived from /Data/Tastytrade/MarketData/Candle (daily close) + /App.Analytics/ImpliedVolatility → IV30_30d",
      "interpretation": "|Z| <= 1.0 → neutral | Z > 1.5 → bullish extremo | Z < -1.5 → bearish extremo"
    },
    "iv_zscore": {
      "type": "formula",
      "formula": "(iv_current - mean(iv_history_252)) / stddev(iv_history_252)",
      "iv_current": "IV30_30d del día",
      "iv_history_252": "serie diaria de IV de los últimos 252 días hábiles",
      "endpoint": "/App.Analytics/IVRank → history[].iv (252 entradas)",
      "interpretation": "iv_zscore > 1.5 → IV cara, régimen de alta vol | iv_zscore < -1.5 → IV barata, régimen de baja vol"
    },
    "gex_skew": {
      "type": "formula",
      "formula": "callGEX / (callGEX + abs(putGEX))",
      "range": "[0.0, 1.0]",
      "interpretation": {
        "gt_0.6": "call_dominant — call wall más fuerte, soporte estructural arriba → favorece put_credit_spread",
        "lt_0.4": "put_dominant — put wall más fuerte, soporte estructural abajo → favorece call_credit_spread",
        "between_0.4_0.6": "symmetric — ancla equilibrada → favorece iron_condor"
      },
      "thresholds": { "call_dominant": 0.6, "put_dominant": 0.4 },
      "note": "Siempre se evalúa dentro de un entorno GEX positivo (macro_regime.gex_total lo garantiza). Mide asimetría direccional de muros, no el signo neto.",
      "endpoint": "/App.Analytics/GammaExposure → callGEX y putGEX"
    },
    "trend_ema": {
      "type": "formula",
      "ema_fast_period": 20,
      "ema_slow_period": 50,
      "formula_ema": "EMA(close, N) = precio_anterior_ema * (1 - 2/(N+1)) + close * (2/(N+1))",
      "trend_up": "ema_20 > ema_50",
      "trend_down": "ema_20 < ema_50",
      "trend_neutral": "abs(ema_20 - ema_50) / ema_50 < 0.002",
      "endpoint": "derived from /Data/Tastytrade/MarketData/Candle?Symbol={SYMBOL}&Interval=1d → close (últimas 60 sesiones)"
    },
    "realized_vol_regime": {
      "type": "formula",
      "log_return": "ln(close_t / close_t-1)",
      "rv_short": "stddev(log_returns, 10) * sqrt(252) * 100",
      "rv_long": "stddev(log_returns, 30) * sqrt(252) * 100",
      "high_vol_regime": "rv_short > rv_long",
      "unit": "percent_annualized",
      "endpoint": "derived from /Data/Tastytrade/MarketData/Candle?Symbol={SYMBOL}&Interval=1d → close (últimas 35 sesiones)"
    },
    "aggressive_flow": {
      "type": "realtime_stream",
      "ask_side_aggression": "trade_price >= quote_ask",
      "bid_side_aggression": "trade_price <= quote_bid",
      "large_premium_formula": "trade_size * trade_price * 100",
      "large_premium_threshold_usd": 25000,
      "oi_opening_proxy": "day_volume / oi_prev_day",
      "oi_opening_proxy_threshold": 0.5,
      "bullish_flow": {
        "conditions": ["call_sweep", "ask_side_aggression", "large_premium >= threshold", "oi_opening_proxy >= 0.5"],
        "net_delta_flow": "net_call_delta_flow > 0"
      },
      "bearish_flow": {
        "conditions": ["put_sweep", "ask_side_aggression", "large_premium >= threshold", "oi_opening_proxy >= 0.5"],
        "net_delta_flow": "net_put_delta_flow < 0"
      },
      "flow_window_minutes": 60,
      "endpoint": "/Data/Tastytrade/MarketData/TradeQuoteGreeks (streaming vía SignalR ReceiveTrade + ReceiveQuote bundled)",
      "oi_prev_day_source": "/Data/Tastytrade/MarketData/Candle → openInterest del último cierre"
    },
    "credit_ratio": {
      "type": "formula",
      "formula": "net_credit / spread_width"
    },
    "credit_ratio_min_by_iv_rank": {
      "type": "lookup_by_range",
      "key": "iv_rank",
      "ranges": [
        { "min": 0,  "max": 35, "value": 0.10 },
        { "min": 35, "max": 50, "value": 0.12 },
        { "min": 50, "max": 100, "value": 0.15 }
      ],
      "range_convention": "min_inclusive_max_exclusive_except_last_inclusive"
    },
    "gex_total": {
      "type": "formula",
      "formula": "sum(open_interest * gamma * 100 * spot^2 * 0.01)",
      "included_expirations": "all_standard_and_weekly_with_dte_lt_90",
      "unit": "billions_usd",
      "refresh_minutes": 15,
      "endpoint": "/App.Analytics/GammaExposure"
    },
    "gex_threshold_by_symbol": {
      "type": "lookup_by_symbol",
      "values": { "SPY": 50, "QQQ": 50 },
      "unit": "billions_usd"
    },
    "gamma_zero_level": {
      "type": "marketdata",
      "definition": "strike_where_cumulative_net_gex_crosses_from_negative_to_positive",
      "refresh_minutes": 15,
      "endpoint": "/App.Analytics/GammaExposure → gammaZeroLevel"
    },
    "zgl_with_buffer": {
      "type": "formula",
      "formula": "gamma_zero_level * (1 + 0.005)",
      "buffer_pct": 0.005
    },
    "call_wall": {
      "type": "marketdata",
      "definition": "strike with highest callGEX",
      "endpoint": "/App.Analytics/GammaExposure → callWall"
    },
    "put_wall": {
      "type": "marketdata",
      "definition": "strike with most negative putGEX",
      "endpoint": "/App.Analytics/GammaExposure → putWall"
    },
    "min_offset_from_spot_by_symbol": {
      "type": "lookup_by_symbol",
      "values": { "SPY": 10, "QQQ": 10 },
      "unit": "points"
    },
    "pop_proxy": {
      "type": "formula",
      "formula": "(1 - abs(short_delta)) * 100",
      "unit": "percent",
      "note": "Proxy de probabilidad de profit basado en el delta de la pata short. No es POP estadístico exacto pero es consistente con Black-Scholes.",
      "applies_per_side": true,
      "for_iron_condor": "min(pop_put_side, pop_call_side)"
    },
    "portfolio_heat": {
      "type": "formula",
      "formula": "sum((spread_width - net_credit) * 100 * contracts) for all open positions",
      "unit": "dollars"
    },
    "heat_pct_net_liq": {
      "type": "formula",
      "formula": "portfolio_heat / net_liq"
    },
    "max_heat": {
      "type": "formula",
      "formula": "net_liq * 0.045"
    },
    "heat_available": {
      "type": "formula",
      "formula": "max_heat - current_heat"
    },
    "new_position_heat": {
      "type": "formula",
      "formula": "(spread_width - net_credit) * 100 * contracts"
    },
    "heat_after_new_position": {
      "type": "formula",
      "formula": "current_heat + new_position_heat"
    },
    "risk_per_trade": {
      "type": "formula",
      "formula": "net_liq * 0.015",
      "risk_per_trade_pct": 0.015
    },
    "max_risk_per_contract": {
      "type": "formula",
      "formula": "(spread_width - net_credit) * 100"
    },
    "max_contracts": {
      "type": "formula",
      "formula": "floor(risk_per_trade / max_risk_per_contract)",
      "floor_min": 1
    },
    "positions_available": {
      "type": "formula",
      "formula": "max_positions - open_positions"
    },
    "bid_ask_spread_pct": {
      "type": "formula",
      "formula": "(ask - bid) / mid",
      "endpoint": "/Data/Tastytrade/MarketData/Quote"
    },
    "slippage_entry": {
      "type": "formula",
      "formula": "(estimated_mid_price - real_fill_price + fees) / estimated_mid_price",
      "reference_point": "when_entry_signal_is_validated_before_order_routing"
    },
    "slippage_roll": {
      "type": "rule",
      "method": "fixed_per_leg_dollars",
      "max_friction_per_leg": 0.05,
      "total_max_4_legs": 0.20
    },
    "spy_exdiv_days_until": {
      "type": "manual",
      "applies_to": ["SPY"],
      "ex_dividend_months": ["marzo", "junio", "septiembre", "diciembre"],
      "ex_dividend_day": "tercer_viernes_del_mes"
    },
    "leg_mid_price": {
      "type": "formula",
      "formula": "(bid + ask) / 2",
      "unit": "dollars_per_contract_unit",
      "source": "socket — ReceiveQuote por símbolo OCC de cada leg",
      "note": "Mid-price en tiempo real por leg. El frontend suscribe cada símbolo OCC via Subscribe(occSymbol) y computa el mid del quote recibido. No usar snapshot REST para display."
    },
    "max_profit": {
      "type": "formula",
      "formula": "net_credit_live * 100 * contracts",
      "unit": "dollars",
      "net_credit_live": "short_put_mid + short_call_mid - long_put_mid - long_call_mid (desde socket)",
      "note": "Se calcula con el crédito neto live del socket. Máxima ganancia si ambas patas expiran OTM."
    },
    "max_loss": {
      "type": "formula",
      "formula": "(spread_width - net_credit_live) * 100 * contracts",
      "unit": "dollars",
      "net_credit_live": "ver leg_mid_price",
      "note": "Pérdida máxima si el spread expira ITM completamente. Se actualiza con crédito live."
    },
    "buying_power_requirement": {
      "type": "formula",
      "formula": "(spread_width - net_credit_live) * 100",
      "unit": "dollars_per_contract",
      "net_credit_live": "ver leg_mid_price",
      "note": "Capital bloqueado por contrato. Se actualiza con crédito live. Idéntico a max_loss por contrato."
    }
  },
  "macro_regime": {
    "name": "macro_regime",
    "description": "Régimen de mercado",
    "pass_rule": "all_checks_pass",
    "on_fail": "short_circuit_no_trade",
    "checks": [
      {
        "id": "vix_absolute",
        "label": "VIX < 30",
        "metric":    { "ref": "marketdata.$VIX.X.price" },
        "operator":  "lt",
        "threshold": { "value": 30 },
        "source": "/Data/Tastytrade/MarketData/ByType?Symbol=$VIX.X",
        "on_fail": "no_trade"
      },
      {
        "id": "vix_term_structure",
        "label": "VIX TS normal (VIX −9d < VIX −30d)",
        "metric":    { "ref": "marketdata.$VIX.X.candle.close_9d_ago" },
        "operator":  "lt",
        "threshold": { "ref": "marketdata.$VIX.X.candle.close_30d_ago" },
        "source": "/Data/Tastytrade/MarketData/Candle?Symbol=$VIX.X&Interval=1d&FromTime={35_trading_days_ago} → close[−9] y close[−30]",
        "polling_interval_minutes": 5,
        "on_fail": "no_trade",
        "note": "VIX de hace 9 sesiones < VIX de hace 30 sesiones indica volatilidad en descenso o estable. Inversión = régimen de estrés activo."
      },
      {
        "id": "iv_rank",
        "label": "IV Rank entre 25 y 65",
        "metric":    { "ref": "definitions.iv_rank" },
        "operator":  "between",
        "threshold": { "min": 25, "max": 65 },
        "source": "/App.Analytics/IVRank",
        "on_fail": "no_trade"
      },
      {
        "id": "iv_momentum",
        "label": "IV aceleración ≤ 12%",
        "metric":    { "ref": "definitions.iv30_atm_roc_pct" },
        "operator":  "lte",
        "threshold": { "value": 12.0 },
        "source": "/App.Analytics/ImpliedVolatility?Symbol={SYMBOL} → IV30RocPct",
        "on_fail": "wait_for_stabilization",
        "note": "IV en expansión rápida indica régimen de stress activo. IV30RocPct = ((IV30_0d − IV30_5d) / IV30_5d) × 100. Ventana de 5 días con umbral ajustado."
      },
      {
        "id": "gex_total",
        "label": "GEX ≥ umbral por símbolo",
        "metric":    { "ref": "definitions.gex_total" },
        "operator":  "gte",
        "threshold": { "ref": "definitions.gex_threshold_by_symbol" },
        "source": "/App.Analytics/GammaExposure",
        "on_fail": "no_trade",
        "note": "Post-OPEX el GEX colapsa — el ZGL sigue pero sin masa detrás."
      },
      {
        "id": "spot_vs_zgl",
        "label": "Spot > ZGL + 0.5%",
        "metric":    { "ref": "marketdata.spot" },
        "operator":  "gt",
        "threshold": { "ref": "definitions.zgl_with_buffer" },
        "source": "/App.Analytics/GammaExposure → gammaZeroLevel",
        "on_fail": "no_trade",
        "note": "Buffer evita operar en la barrera donde el ancla es inestable."
      },
      {
        "id": "spy_exdiv_warn",
        "label": "SPY Ex-Div — warn ≤ 7d",
        "applies_to_symbol": ["SPY"],
        "applies_to_side": "call",
        "metric":    { "ref": "definitions.spy_exdiv_days_until" },
        "operator":  "lte",
        "threshold": { "value": 7 },
        "source": "manual_check",
        "on_fail": "warn",
        "note": "Riesgo de asignación temprana en calls ITM antes del corte de dividendo."
      },
      {
        "id": "spy_exdiv_block_call",
        "label": "SPY Ex-Div — block call entries ≤ 3d",
        "applies_to_symbol": ["SPY"],
        "applies_to_side": "call",
        "metric":    { "ref": "definitions.spy_exdiv_days_until" },
        "operator":  "lte",
        "threshold": { "value": 3 },
        "source": "manual_check",
        "on_fail": "block_new_call_entries"
      }
    ]
  },
  "position_builder": {
    "description": "Motor de construcción de posición. Se evalúa solo si macro_regime pasa.",
    "cascade_rule": "sequential_short_circuit",
    "layers": [
      {
        "id": 2,
        "name": "strike_engine",
        "description": "Estructura, expiración, strikes y anchos. Si ningún lado pasa, no operar. Si solo un lado pasa, evaluar degradación.",
        "pass_rule": "at_least_one_side_passes_all_checks",
        "on_layer_fail": "short_circuit_no_trade",
        "config": {
          "dte_selection": {
            "target": 45,
            "min": 35,
            "max": 45,
            "expiration_preference": "monthly_regular",
            "allow_weeklies": true,
            "weekly_condition": "only_if_monthly_outside_dte_and_liquidity_met"
          },
          "structure_selection": {
            "method": "multi_factor",
            "description": "Selección de estructura basada en 4 dimensiones activas: z-score de precio, asimetría de GEX (skew), flow agresivo y tendencia EMA.",
            "thresholds": {
              "neutral_z": 1.0,
              "extreme_z": 1.5
            },
            "inputs": {
              "price_zscore": { "ref": "definitions.directional_zscore" },
              "gex_skew":     { "ref": "definitions.gex_skew" },
              "trend":        { "ref": "definitions.trend_ema" },
              "flow":         { "ref": "definitions.aggressive_flow" }
            },
            "evaluation_order": "sequential_first_match",
            "rules": [
              {
                "id": 1,
                "name": "neutral_symmetric_gex",
                "label": "Mercado neutro — GEX simétrico",
                "conditions": {
                  "price_zscore_abs": "< neutral_z (1.0)",
                  "gex_skew": "symmetric"
                },
                "output": "iron_condor",
                "rationale": "Precio en zona central, call wall y put wall equidistantes. Ancla equilibrada. Escenario óptimo para vender prima por ambos lados."
              },
              {
                "id": 2,
                "name": "bullish_call_dominant",
                "label": "Alcista — Call Wall dominante + Bullish Flow",
                "conditions": {
                  "price_zscore": "> extreme_z (1.5)",
                  "gex_skew": "call_dominant",
                  "flow": "bullish",
                  "trend": "up"
                },
                "output": "put_credit_spread",
                "rationale": "Precio extendido al alza. Call wall fuerte crea soporte estructural arriba. Flow y trend confirman. Vender put premium debajo del movimiento con el muro de calls como respaldo."
              },
              {
                "id": 3,
                "name": "bearish_put_dominant",
                "label": "Bajista — Put Wall dominante + Bearish Flow",
                "conditions": {
                  "price_zscore": "< -extreme_z (-1.5)",
                  "gex_skew": "put_dominant",
                  "flow": "bearish",
                  "trend": "down"
                },
                "output": "call_credit_spread",
                "rationale": "Precio extendido a la baja. Put wall fuerte crea soporte estructural abajo. Flow y trend confirman. Vender call premium arriba del movimiento."
              },
              {
                "id": 4,
                "name": "bullish_exhaustion",
                "label": "Agotamiento alcista — Put Wall dominante + Bearish Flow",
                "conditions": {
                  "price_zscore": "> extreme_z (1.5)",
                  "gex_skew": "put_dominant",
                  "flow": "bearish"
                },
                "output": "call_credit_spread",
                "rationale": "Precio extendido arriba pero el put wall domina (soporte abajo, no arriba). Flow contrarian bajista confirma agotamiento. Mean reversion probable."
              },
              {
                "id": 5,
                "name": "bearish_exhaustion",
                "label": "Agotamiento bajista — Call Wall dominante + Bullish Flow",
                "conditions": {
                  "price_zscore": "< -extreme_z (-1.5)",
                  "gex_skew": "call_dominant",
                  "flow": "bullish"
                },
                "output": "put_credit_spread",
                "rationale": "Precio extendido abajo pero el call wall domina (soporte arriba). Flow contrarian alcista confirma agotamiento. Mean reversion probable."
              },
              {
                "id": 6,
                "name": "no_trade_fallthrough",
                "label": "Sin señal — ninguna condición satisfecha",
                "conditions": "fallthrough",
                "output": "no_trade",
                "rationale": "El mercado no presenta un régimen claro. Cash es una posición."
              }
            ]
          },
          "spread_width": {
            "symbol_overrides": {
              "SPY": { "default": 10, "min": 5, "max": 15, "step": 5 },
              "QQQ": { "default": 5,  "min": 5, "max": 10, "step": 5 }
            },
            "unit": "points",
            "selection_rule": "Empezar por default. Si credit_ratio < min, probar default+step. Si al llegar a max sigue sin cumplir, descartar ese lado."
          },
          "asymmetry_check": {
            "enabled": true,
            "distance_ratio_threshold": 2.5,
            "absolute_distance_min_ref": "definitions.min_offset_from_spot_by_symbol",
            "on_trigger": "switch_to_one_sided_credit_spread"
          }
        },
        "checks": [
          {
            "id": "put_strike_outside_wall",
            "label": "Put strike < Put Wall",
            "side": "put",
            "metric":    { "ref": "calc.put_strike" },
            "operator":  "lt",
            "threshold": { "ref": "definitions.put_wall" },
            "source": "/App.Analytics/GammaExposure → putWall",
            "on_fail": "discard_put_side"
          },
          {
            "id": "put_strike_delta",
            "label": "|Δ put short| ≤ 0.30",
            "side": "put",
            "metric":    { "ref": "calc.put_short_delta_abs" },
            "operator":  "lte",
            "threshold": { "value": 0.30 },
            "source": "/Data/Tastytrade/MarketData/Greeks",
            "on_fail": "discard_put_side"
          },
          {
            "id": "put_strike_min_offset",
            "label": "(Spot − Put) ≥ offset mínimo",
            "side": "put",
            "metric":    { "ref": "calc.spot_minus_put_strike" },
            "operator":  "gte",
            "threshold": { "ref": "definitions.min_offset_from_spot_by_symbol" },
            "source": "calc",
            "on_fail": "discard_put_side"
          },
          {
            "id": "put_credit_ratio",
            "label": "Credit ratio put ≥ mínimo por IVR",
            "side": "put",
            "metric":    { "ref": "calc.put_credit_ratio" },
            "operator":  "gte",
            "threshold": { "ref": "definitions.credit_ratio_min_by_iv_rank" },
            "source": "calc",
            "on_fail": "try_wider_spread_then_discard"
          },
          {
            "id": "call_strike_outside_wall",
            "label": "Call strike > Call Wall",
            "side": "call",
            "metric":    { "ref": "calc.call_strike" },
            "operator":  "gt",
            "threshold": { "ref": "definitions.call_wall" },
            "source": "/App.Analytics/GammaExposure → callWall",
            "on_fail": "discard_call_side"
          },
          {
            "id": "call_strike_delta",
            "label": "|Δ call short| ≤ 0.25",
            "side": "call",
            "metric":    { "ref": "calc.call_short_delta_abs" },
            "operator":  "lte",
            "threshold": { "value": 0.25 },
            "source": "/Data/Tastytrade/MarketData/Greeks",
            "on_fail": "discard_call_side"
          },
          {
            "id": "call_strike_min_offset",
            "label": "(Call − Spot) ≥ offset mínimo",
            "side": "call",
            "metric":    { "ref": "calc.call_strike_minus_spot" },
            "operator":  "gte",
            "threshold": { "ref": "definitions.min_offset_from_spot_by_symbol" },
            "source": "calc",
            "on_fail": "discard_call_side"
          },
          {
            "id": "call_credit_ratio",
            "label": "Credit ratio call ≥ mínimo por IVR",
            "side": "call",
            "metric":    { "ref": "calc.call_credit_ratio" },
            "operator":  "gte",
            "threshold": { "ref": "definitions.credit_ratio_min_by_iv_rank" },
            "source": "calc",
            "on_fail": "try_wider_spread_then_discard"
          },
          {
            "id": "skew_degradation",
            "label": "Skew → degradar IC a PCS",
            "operator":  "custom",
            "rule": "if call_side_discarded AND put_side_passes_all → structure = put_credit_spread",
            "on_fail": "degrade_structure",
            "note": "Con GEX > 50B y VIX < 15 el call side sin crédito es comportamiento esperado del skew — degradar a PCS en lugar de rechazar."
          }
        ]
      },
      {
        "id": 3,
        "name": "microstructure",
        "description": "Liquidez, calidad de quote y crédito mínimo. Aplica por cada leg seleccionado.",
        "pass_rule": "all_checks_pass_for_selected_legs",
        "on_layer_fail": "short_circuit_no_trade",
        "checks": [
          {
            "id": "oi_short_leg",
            "label": "OI short ≥ 2000",
            "applies_per_leg": "short",
            "metric":    { "ref": "marketdata.leg.openInterest" },
            "operator":  "gte",
            "threshold": { "value": 2000 },
            "source": "/Data/Tastytrade/MarketData/Candle → openInterest",
            "on_fail": "discard_side"
          },
          {
            "id": "oi_long_leg",
            "label": "OI long ≥ 2000",
            "applies_per_leg": "long",
            "metric":    { "ref": "marketdata.leg.openInterest" },
            "operator":  "gte",
            "threshold": { "value": 2000 },
            "source": "/Data/Tastytrade/MarketData/Candle → openInterest",
            "on_fail": "discard_side"
          },
          {
            "id": "bid_ask_spread",
            "label": "B/A ≤ 5% mid",
            "applies_per_leg": "all",
            "metric":    { "ref": "definitions.bid_ask_spread_pct" },
            "operator":  "lte",
            "threshold": { "value": 0.05 },
            "source": "/Data/Tastytrade/MarketData/Quote",
            "on_fail": "discard_side"
          },
          {
            "id": "quote_freshness",
            "label": "Quote < 15s",
            "applies_per_leg": "all",
            "metric":    { "ref": "marketdata.leg.quote_age_seconds" },
            "operator":  "lte",
            "threshold": { "value": 15 },
            "source": "data_quality.max_quote_age_seconds",
            "on_fail": "block_until_fresh"
          },
          {
            "id": "credit_minimum",
            "label": "Crédito ≥ $0.30",
            "applies_per_spread": true,
            "metric":    { "ref": "calc.spread_mid_credit" },
            "operator":  "gte",
            "threshold": { "value": 0.30 },
            "source": "/Data/Tastytrade/MarketData/Quote → mid del spread combinado",
            "on_fail": "try_wider_spread_then_discard"
          }
        ]
      },
      {
        "id": 4,
        "name": "risk_and_sizing",
        "description": "Sizing y verificación de que el riesgo incremental no excede límites del portafolio.",
        "pass_rule": "all_checks_pass",
        "on_layer_fail": "short_circuit_no_trade",
        "config": {
          "risk_per_trade_pct": 0.015,
          "max_positions": 3,
          "max_heat_pct_net_liq": 0.045
        },
        "checks": [
          {
            "id": "max_contracts_viable",
            "label": "Contratos máx ≥ 1",
            "metric":    { "ref": "definitions.max_contracts" },
            "operator":  "gte",
            "threshold": { "value": 1 },
            "source": "calc",
            "on_fail": "no_trade",
            "note": "Si el riesgo por contrato supera el 1.5% del Net Liq, no operar."
          },
          {
            "id": "positions_available",
            "label": "Slots disponibles ≥ 1",
            "metric":    { "ref": "definitions.positions_available" },
            "operator":  "gte",
            "threshold": { "value": 1 },
            "source": "account.positions",
            "on_fail": "no_trade"
          },
          {
            "id": "heat_after_entry",
            "label": "Heat total ≤ 4.5% NL",
            "metric":    { "ref": "definitions.heat_after_new_position" },
            "operator":  "lte",
            "threshold": { "ref": "definitions.max_heat" },
            "source": "calc",
            "on_fail": "reduce_contracts_to_fit_or_discard"
          }
        ]
      }
    ]
  },
  "execution": {
    "submit_multileg_as_complex_order": true,
    "avoid_first_minutes_open": 20,
    "avoid_last_minutes_close": 20,
    "partial_fill_policy": {
      "max_unresolved_seconds": 20,
      "cleanup_method": "aggressive_limit_ladder",
      "block_new_entries_until_resolved": true,
      "raise_critical_alert_on_cleanup_failure": true,
      "if_manual_unavailable_continue_flatten_until_flat": true
    },
    "forced_exit_policy": {
      "applies_to": ["macro_event_binary_avoidance", "operational_contingency_cleanup", "hard_risk_emergency"],
      "method": "marketable_limit_ladder",
      "ignore_entry_slippage_limits": true,
      "override_standard_entry_time_windows": true
    },
    "slippage": {
      "new_entries": {
        "max_total_cost_pct_of_expected_credit": 0.10
      },
      "defensive_rolls": {
        "formula_ref": "definitions.slippage_roll"
      }
    }
  },
  "trade_management": {
    "evaluation_priority": [
      "operational_contingency",
      "macro_event_binary_avoidance",
      "daily_kill_switch",
      "take_profit",
      "structural_support_loss",
      "hard_defense",
      "defensive_roll",
      "time_exit"
    ],
    "daily_kill_switch": {
      "daily_portfolio_mtm_loss_pct_net_liq_max": 0.015,
      "action": "block_new_entries_for_rest_of_session"
    },
    "take_profit": {
      "pct_of_initial_credit": 0.5,
      "action": "close_position"
    },
    "macro_event_binary_avoidance": {
      "trigger": "entered_macro_event_buffer_window",
      "action": "close_position_before_window_starts"
    },
    "structural_support_loss": {
      "trigger": "relevant_wall_moves_inside_short_strike",
      "confirm_consecutive_recalculations": 2,
      "action": "close_position"
    },
    "hard_defense": {
      "trigger_any": {
        "short_leg_delta_abs_gt": 0.30,
        "unrealized_loss_pct_of_initial_credit_gte": 2.0
      },
      "action": "evaluate_immediate_risk_reduction"
    },
    "defensive_roll": {
      "trigger_unrealized_loss_pct_of_initial_credit_gte": 1.0,
      "min_dte_remaining": 28,
      "min_net_credit_for_roll": 0.20,
      "max_rolls_per_position": 1,
      "slippage_rule_ref": "definitions.slippage_roll"
    },
    "time_exit": {
      "dte_threshold": 21,
      "action": "close_position"
    }
  },
  "monitoring": {
    "review_frequency_minutes": 30
  },
  "display_config": {
    "checks_render_order": "macro_regime.checks[] en orden de declaración / position_builder.layers[].checks[] en orden de declaración",
    "portfolio_manager_table": {
      "description": "Columnas del Portfolio Manager. El frontend debe renderizar exactamente estas columnas en este orden, leyendo los campos del endpoint /App/GaleCore/PositionBuilder.",
      "columns": [
        { "id": "ticker",           "label": "Ticker",             "source": "symbol" },
        { "id": "signal",           "label": "Señal",              "source": "overallSignal" },
        { "id": "price",            "label": "Precio Actual",      "source": "spotPrice" },
        { "id": "call_wall",        "label": "Call Wall",          "source": "strikeEngine.callWall",           "ref": "definitions.call_wall" },
        { "id": "zgl",              "label": "ZGL",                "source": "gammaZeroLevel",                  "ref": "definitions.gamma_zero_level" },
        { "id": "put_wall",         "label": "Put Wall",           "source": "strikeEngine.putWall",            "ref": "definitions.put_wall" },
        { "id": "z_spot",           "label": "Z-Spot",             "source": "structureInputs.priceZScore.value", "ref": "definitions.directional_zscore" },
        { "id": "gex",              "label": "GEX",                "source": "netGexBillions",                  "ref": "definitions.gex_total", "unit": "billions_usd" },
        { "id": "expected_move",    "label": "Expected Move",      "source": "strikeEngine.expectedMove",       "ref": "definitions.expected_move" },
        { "id": "structure",        "label": "Posición Sugerida",  "source": "selectedStructure.output" },
        { "id": "long_put",         "label": "Long Put",           "source": "strikeEngine.longPutStrike",      "group": "strikes" },
        { "id": "short_put",        "label": "Short Put",          "source": "strikeEngine.shortPutStrike",     "group": "strikes" },
        { "id": "short_call",       "label": "Short Call",         "source": "strikeEngine.shortCallStrike",    "group": "strikes" },
        { "id": "long_call",        "label": "Long Call",          "source": "strikeEngine.longCallStrike",     "group": "strikes" },
        { "id": "prem_long_put",    "label": "Long Put",           "source": "socket.ReceiveQuote[strikeEngine.legSymbols.longPut]",   "ref": "definitions.leg_mid_price", "group": "premium", "realtime": true },
        { "id": "prem_short_put",   "label": "Short Put",          "source": "socket.ReceiveQuote[strikeEngine.legSymbols.shortPut]",  "ref": "definitions.leg_mid_price", "group": "premium", "realtime": true },
        { "id": "prem_short_call",  "label": "Short Call",         "source": "socket.ReceiveQuote[strikeEngine.legSymbols.shortCall]", "ref": "definitions.leg_mid_price", "group": "premium", "realtime": true },
        { "id": "prem_long_call",   "label": "Long Call",          "source": "socket.ReceiveQuote[strikeEngine.legSymbols.longCall]",  "ref": "definitions.leg_mid_price", "group": "premium", "realtime": true },
        { "id": "net_credit",       "label": "Net Credit",         "source": "socket — computed from live leg quotes", "ref": "definitions.leg_mid_price", "realtime": true, "formula": "short_put_mid + short_call_mid - long_put_mid - long_call_mid" },
        { "id": "pop",              "label": "POP",                "source": "strikeEngine.pop",                "ref": "definitions.pop_proxy" },
        { "id": "max_profit",       "label": "Máx Profit",         "source": "riskAndSizing.maxProfit",         "ref": "definitions.max_profit" },
        { "id": "max_loss",         "label": "Máx Drawdown",       "source": "riskAndSizing.maxLoss",           "ref": "definitions.max_loss" },
        { "id": "bpr",              "label": "BPR",                "source": "riskAndSizing.buyingPowerReq",    "ref": "definitions.buying_power_requirement" }
      ],
      "column_groups": [
        { "id": "strikes", "label": "Strikes",  "columns": ["long_put", "short_put", "short_call", "long_call"] },
        { "id": "premium", "label": "Premium",  "columns": ["prem_long_put", "prem_short_put", "prem_short_call", "prem_long_call"] }
      ]
    },
    "alerts_priority": [
      "STOP_LOSS",
      "TIME_EXIT",
      "DELTA_BREACH",
      "SPY_EXDIV_BLOCK",
      "EVALUAR_ROLL",
      "PROFIT_TARGET",
      "SPY_EXDIV_WARN",
      "MACRO_PROXIMO"
    ],
    "signal_labels": {
      "OPERAR": {
        "color": "green",
        "condition": "macro_regime_pass AND all_position_builder_layers_pass"
      },
      "OPERAR_PCS": {
        "color": "green",
        "condition": "macro_regime_pass AND strike_engine_skew_degradation AND microstructure_pass AND risk_sizing_pass"
      },
      "ESPERAR": {
        "color": "yellow",
        "condition": "macro_regime_pass AND position_builder_partial_fail"
      },
      "NO_OPERAR": {
        "color": "red",
        "condition": "macro_regime_fail OR position_builder_short_circuit"
      }
    }
  }
}
